# Supabase — copy this file to `.env` and fill in values from your project's
# Settings → API page. These are safe to ship in a client app (the anon key is
# protected by Row-Level Security). NEVER put the service_role key here.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
