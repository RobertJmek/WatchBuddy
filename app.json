{
  "expo": {
    "name": "WatchBuddy",
    "slug": "watchbuddy",
    "version": "1.6.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "watchbuddy",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "com.robertjmek.watchbuddy",
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0D9488",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.robertjmek.watchbuddy",
      "versionCode": 19
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow WatchBuddy to access your photos to set a profile picture.",
          "microphonePermission": false
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0D9488",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 180,
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 180
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5751393f-b11d-41c0-921e-2f48afe154e7"
      }
    },
    "owner": "robertjmek"
  }
}
